{
  "manifest_version": 3,
  "name": "ChatGPT Exporter",
  "version": "2.30.0",
  "description": "Easily export ChatGPT conversation history and auto-save to WebDAV.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://new.oaifree.com/*",
    "*://*/*"
  ],
  "content_scripts": [
    {
      "world": "MAIN",
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://new.oaifree.com/*"
      ],
      "js": ["src/main.tsx"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ChatGPT Exporter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
